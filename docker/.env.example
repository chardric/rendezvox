# ==========================================================
# RendezVox — Environment Variables
# ==========================================================
# Quick start:
#   bash setup.sh && docker compose up -d
#
# setup.sh auto-generates credentials and detects an
# available port. You only need to touch this file to
# change timezone or port after initial setup.
# ==========================================================

# ── Auto-generated credentials (do not share) ────────────
POSTGRES_PASSWORD=         # auto-generated by setup.sh
ICECAST_SOURCE_PASSWORD=   # auto-generated by setup.sh
ICECAST_ADMIN_PASSWORD=    # auto-generated by setup.sh

# ── User settings (edit these as needed) ──────────────────
RENDEZVOX_APP_ENV=production
TZ=UTC
RENDEZVOX_HTTP_PORT=8888
